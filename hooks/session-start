#!/usr/bin/env bash
# SessionStart hook for superpowers-copilot plugin
# In Copilot CLI, sessionStart output is IGNORED by the agent.
# Context injection is handled by the prompt hook in hooks.json.
# This script handles side effects only: legacy detection and logging.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read input from stdin (Copilot CLI passes session info as JSON)
INPUT=$(cat 2>/dev/null || echo '{}')

# Check for legacy Claude Code superpowers installation
legacy_claude_skills="${HOME}/.claude/skills/superpowers"
legacy_config_skills="${HOME}/.config/superpowers/skills"

if [ -d "$legacy_claude_skills" ] || [ -d "$legacy_config_skills" ]; then
    # Log warning (output is ignored by agent, but visible in hook logs)
    echo '{"warning":"Legacy superpowers installation detected. This Copilot CLI plugin replaces the Claude Code version. Remove old installations to avoid conflicts."}' >&2
fi

# Log session start for debugging (to stderr, not consumed by agent)
timestamp=$(date +%s)
echo "[superpowers] Session started at ${timestamp}" >&2

exit 0
