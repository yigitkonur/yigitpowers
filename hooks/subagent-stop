#!/usr/bin/env bash
# SubagentStop hook for yigitpowers
# Triggered when a dispatched subagent completes its task.
# Provides context about the completed subagent to help the controller
# decide next steps (e.g., dispatch reviewer, mark task complete).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

reminder="After a subagent completes work, follow the superpowers workflow:\\n\\n1. If this was an **implementer** subagent: dispatch the **spec-reviewer** subagent to verify spec compliance\\n2. If this was a **spec-reviewer** subagent and it passed: dispatch the **code-quality-reviewer** subagent\\n3. If this was a **spec-reviewer** or **code-quality-reviewer** subagent and it found issues: dispatch the implementer again to fix them\\n4. If this was the final **code-reviewer** subagent: proceed to **finishing-a-development-branch**\\n5. Mark completed tasks in TodoWrite\\n\\nDo NOT skip review stages. Do NOT proceed with unfixed issues."

reminder_escaped=$(escape_for_json "$reminder")

# Output context injection
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SubagentStop",
    "additionalContext": "${reminder_escaped}"
  }
}
EOF
else
  cat <<EOF
{
  "additional_context": "${reminder_escaped}"
}
EOF
fi

exit 0
